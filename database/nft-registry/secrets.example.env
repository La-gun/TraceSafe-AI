# Example for: npx base44 secrets set --env-file secrets.local.env
# 1. Copy this file to secrets.local.env (gitignored).
# 2. Replace NFT_REGISTRY_DATABASE_URL with your hosted Postgres URL (not localhost for deployed functions).
# 3. Run from repo root: npx base44 secrets set --env-file database/nft-registry/secrets.local.env

NFT_REGISTRY_DATABASE_URL=postgres://USER:PASSWORD@YOUR_HOST:5432/nft_registry
NFT_REGISTRY_TENANT_EXTERNAL_KEY=default
NFT_REGISTRY_TENANT_DISPLAY_NAME=TraceSafe
NFT_REGISTRY_SYNC_STRICT=false
